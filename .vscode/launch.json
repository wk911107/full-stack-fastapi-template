{
    "version": "0.2.0",
    "configurations": [
        {
        "name": "Debug FastAPI",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
            "app.main:app",
            "--reload"
        ],
        "cwd": "${workspaceFolder}/backend",
        },
        {
            "name": "Frontend",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/frontend",
            "preLaunchTask": "Start Frontend", 
        }
    ],
    "compounds": [
        {
            "name": "🚀 全栈一键调试",
            "configurations": ["Debug FastAPI", "Frontend"],
            "stopAll": true
        }
    ]
}